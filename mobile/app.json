{
  "expo": {
    "name": "AGRO PIPES",
    "slug": "agro-pipes-mobile",
    "version": "2.1.1",
    "orientation": "portrait",
    "icon": "./assets/agro-pipes-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/agro-pipes-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f3020"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/agro-pipes-logo.png",
        "backgroundColor": "#1a5c35"
      },
      "package": "com.agropipes.mobile",
      "versionCode": 5,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.agropipes.mobile"
    },
    "plugins": [
      "expo-local-authentication",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "agro-pipes-mobile"
      }
    }
  }
}
